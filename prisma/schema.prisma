generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Style {
  id          String   @id @default(cuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  price         Float
  originalPrice Float?
  category      String
  style         String
  description   String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id            String      @id @default(cuid())
  customerName  String
  phone         String
  email         String      @default("")
  address       String
  total         Float
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String
  quantity  Int
  price     Float
  imageUrl  String?
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
}

enum NailSize {
  S
  M
  L
}

enum NailShape {
  SHORT_ALMOND
  MEDIUM_ALMOND
  LONG_ALMOND
  COFFIN
  XXXL_COFFIN
}

model CustomOrder {
  id            String      @id @default(cuid())
  customerName  String
  phone         String
  email         String      @default("")
  address       String?
  inspoImage    String
  nailSize      NailSize
  nailShape     NailShape
  total         Float       @default(45.00)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
